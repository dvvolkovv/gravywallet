# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '13.4'
prepare_react_native_project!

# Required so RNFB ships Firebase as static frameworks under use_frameworks!
$RNFirebaseAsStaticFramework = true

target 'trusteeWallet' do
  use_frameworks! :linkage => :static
  config = use_native_modules!

  source 'https://cdn.cocoapods.org/'

  use_react_native!(
    :path => config[:reactNativePath],
    # Flipper doesn't support use_frameworks! — keep disabled.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  pod 'RNVectorIcons', :path => '../node_modules/react-native-vector-icons', :modular_headers => true

  pod 'Permission-FaceID', :path => "../node_modules/react-native-permissions/ios/FaceID", :modular_headers => true
  pod 'Permission-Camera', :path => "../node_modules/react-native-permissions/ios/Camera", :modular_headers => true

  pod 'lottie-react-native', :path => '../node_modules/lottie-react-native', :modular_headers => true

  pod 'glog', :podspec => '../node_modules/react-native/third-party-podspecs/glog.podspec', :modular_headers => true

  target 'trusteeWalletTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.4'
      end

      # RNZipArchive's podspec injects a malformed -GCC_PREPROCESSOR_DEFINITIONS flag
      # (missing space) that newer clang rejects as "unsupported option '-G'". Strip
      # it and recreate the defines via the proper build setting.
      if target.name == 'RNZipArchive'
        target.build_configurations.each do |config|
          flags = Array(config.build_settings['OTHER_CFLAGS'])
          config.build_settings['OTHER_CFLAGS'] = flags.reject { |f| f.to_s.start_with?('-G') }
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = [
            '$(inherited)',
            'HAVE_INTTYPES_H=1',
            'HAVE_PKCRYPT=1',
            'HAVE_STDINT_H=1',
            'HAVE_WZAES=1',
            'HAVE_ZLIB=1',
            'MZ_ZIP_NO_SIGNING=1'
          ]
        end
      end
    end
  end
end
